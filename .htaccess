# ============================================================
#  MANDALA GALLERY — .htaccess
#  Place in your public_html folder root
# ============================================================

Options -Indexes
Options -MultiViews

# ── SECURITY HEADERS ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── BLOCK DIRECT ACCESS TO SENSITIVE FILES ───────────────────
<FilesMatch "^(config|auth)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|env|log|sh|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── BLOCK ACCESS TO UPLOADS RAW (serve via PHP only) ─────────
# (optional — comment out if images stop showing)
# <FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
#     Order Allow,Deny
#     Deny from all
# </FilesMatch>

# ── PHP SETTINGS ─────────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize  10M
    php_value post_max_size        12M
    php_value max_execution_time   60
    php_value memory_limit        128M
</IfModule>

# Alternate for PHP-CGI / suPHP
<IfModule mod_suphp.c>
    suPHP_ConfigPath /etc/php
</IfModule>

# ── GZIP COMPRESSION ─────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── BROWSER CACHING ──────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg     "access plus 7 days"
    ExpiresByType image/png      "access plus 7 days"
    ExpiresByType image/webp     "access plus 7 days"
    ExpiresByType text/css       "access plus 1 day"
    ExpiresByType text/javascript "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
</IfModule>

# ── REWRITE ENGINE ───────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (uncomment once SSL is active)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove .html extension from URLs
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ $1.html [L]

    # Protect uploads folder from directory listing
    RewriteRule ^uploads/$ - [F,L]
</IfModule>
